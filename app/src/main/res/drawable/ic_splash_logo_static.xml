        android:fillColor="#FFFFFFFF"
        android:pathData="M7.3,8 L16.7,8 Q18,8 18,9.3 L18,14.7 Q18,16 16.7,16 L7.3,16 Q6,16 6,14.7 L6,9.3 Q6,8 7.3,8 Z" />

