<?xml version="1.0" encoding="utf-8"?>
<!-- AnimatedVectorDrawable: usa ic_splash_card_src como base e aplica
     splash_scale_in sobre o grupo "card" para criar o efeito de "pop". -->
<animated-vector
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@drawable/ic_splash_card_src">

    <target
        android:name="card"
        android:animation="@animator/splash_scale_in" />

</animated-vector>

