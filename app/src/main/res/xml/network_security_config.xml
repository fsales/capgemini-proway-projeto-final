<?xml version="1.0" encoding="utf-8"?>
<network-security-config xmlns:tools="http://schemas.android.com/tools">
    <!--
        O Mastra local roda em HTTP durante desenvolvimento.
        Para dispositivo fisico, o IP da maquina muda por rede; por isso o
        cleartext fica liberado no base-config. Restrinja este arquivo antes
        de publicar uma build de producao.
    -->
    <base-config cleartextTrafficPermitted="true" />

    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true" tools:ignore="NetworkSecurityConfig">127.0.0.1</domain>
        <domain includeSubdomains="true" tools:ignore="NetworkSecurityConfig">10.0.2.2</domain>
        <domain includeSubdomains="true" tools:ignore="NetworkSecurityConfig">10.0.3.2</domain>
    </domain-config>
</network-security-config>
